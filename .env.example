# Copy to .env (already in .gitignore via standard pattern). docker-compose
# substitutes ${UID} / ${GID} into the `user:` directive on the dev /
# dev-web services so the container writes files as the host user
# instead of root. Without this, paraglide / openapi codegen / pnpm
# install produce root-owned files in the bind-mounted workspace and
# host-side pnpm calls later trip EACCES.
#
# On a typical Linux desktop these are 1000:1000; if you're on macOS
# Docker Desktop the values are still meaningful but the file
# ownership mapping is virtualised so the friction is smaller.
#
# To find your values: `id -u` and `id -g`.
UID=1000
GID=1000
