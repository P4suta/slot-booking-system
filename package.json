{
  "name": "slot-booking-system",
  "private": true,
  "version": "0.0.0",
  "description": "Generic time-slot booking system. Industry-agnostic core with deployable apps.",
  "license": "(Apache-2.0 OR MIT)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:property": "pnpm -F @booking/core run test:property",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "arch": "depcruise --config .dependency-cruiser.cjs packages apps"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "latest",
    "@biomejs/biome": "latest",
    "dependency-cruiser": "latest",
    "eslint": "latest",
    "knip": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "cookie@<0.7.0": "^0.7.0"
    }
  }
}
