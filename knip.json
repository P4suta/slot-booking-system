{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/core": {
      "entry": ["test/**/*.test.ts", "test/**/*.bench.ts", "test/_fixtures/index.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/default": {
      "project": ["src/**/*.ts"],
      "wrangler": {
        "config": ["wrangler.toml"]
      }
    }
  }
}
