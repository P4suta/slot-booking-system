{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": ["tsx"],
  "workspaces": {
    "scripts": {
      "entry": [
        "check.ts",
        "dev-exec.ts",
        "diagnose.ts",
        "diagnose/multiAngle.ts",
        "fuzz/runSoak.ts",
        "lint/comment-bans.ts",
        "test/runner.ts",
        "test/**/*.test.ts"
      ],
      "project": ["**/*.ts"],
      "ignoreDependencies": ["tsx"]
    },
    "packages/core": {
      "entry": ["test/**/*.test.ts", "test/**/*.bench.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/default": {
      "entry": ["test/**/*.test.ts", "test/integration/**/*.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"],
      "wrangler": {
        "config": ["wrangler.toml"]
      }
    },
    "apps/web": {
      "entry": ["src/routes/**/*.{svelte,ts}", "src/app.html", "test/**/*.test.ts"],
      "project": ["src/**/*.{ts,svelte}", "test/**/*.ts"],
      "ignoreDependencies": ["@booking/core", "@cloudflare/workers-types"]
    }
  }
}
