{
  "name": "default",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Industry-agnostic demo deployment of the booking-system core.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "echo 'no tests in default app yet'",
    "test:coverage": "echo 'no tests in default app yet'",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "seed:render": "tsx seed/seed.ts"
  },
  "dependencies": {
    "@booking/core": "workspace:*",
    "@js-temporal/polyfill": "latest",
    "@microlabs/otel-cf-workers": "latest",
    "@opentelemetry/api": "latest",
    "@pothos/core": "latest",
    "@pothos/plugin-errors": "latest",
    "drizzle-orm": "rc",
    "effect": "beta",
    "graphql": "latest",
    "graphql-yoga": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "cloudflare": "latest",
    "drizzle-kit": "rc",
    "tsx": "latest",
    "wrangler": "latest"
  }
}
