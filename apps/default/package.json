{
  "name": "default",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Industry-agnostic demo deployment of the booking-system core.",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --test-scheduled --var IS_DEV:1 --var OTEL_EXPORTER_URL:console",
    "build": "wrangler deploy --dry-run --outdir dist",
    "openapi:write": "tsx scripts/write-openapi-json.ts",
    "test": "vitest run",
    "test:fast": "vitest run --project=node",
    "test:integration": "vitest run --project=workers",
    "test:coverage": "vitest run --coverage --project node",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "seed:render": "tsx seed/seed.ts",
    "size-limit": "size-limit"
  },
  "size-limit": [
    {
      "name": "worker bundle (uncompressed)",
      "path": "dist/index.js",
      "limit": "1 MB",
      "brotli": false,
      "gzip": false
    }
  ],
  "dependencies": {
    "@booking/core": "workspace:*",
    "@booking/push": "workspace:*",
    "@microlabs/otel-cf-workers": "latest",
    "@opentelemetry/api": "latest",
    "drizzle-orm": "rc",
    "effect": "beta",
    "hono": "latest",
    "jose": "latest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "@cloudflare/workers-types": "latest",
    "@opentelemetry/sdk-trace-base": "latest",
    "@size-limit/file": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "cloudflare": "latest",
    "drizzle-kit": "rc",
    "fast-check": "latest",
    "size-limit": "latest",
    "tsx": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
