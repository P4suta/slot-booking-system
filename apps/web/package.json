{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SvelteKit frontend (customer + staff) for the booking system.",
  "scripts": {
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy globalVariable baseLocale --is-server 'import.meta.env.SSR' --emit-ts-declarations --no-emit-readme --silent",
    "codegen": "pnpm run paraglide",
    "dev": "pnpm run codegen && vite dev",
    "build": "pnpm run codegen && vite build",
    "preview": "vite preview",
    "check": "pnpm run codegen && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run codegen && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run"
  },
  "dependencies": {
    "@booking/core": "workspace:*"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "latest",
    "@cloudflare/workers-types": "latest",
    "@inlang/paraglide-js": "latest",
    "@sveltejs/adapter-cloudflare": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@types/node": "latest",
    "gql.tada": "latest",
    "graphql": "latest",
    "svelte": "latest",
    "svelte-check": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
