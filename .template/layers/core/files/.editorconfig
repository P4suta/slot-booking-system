# https://editorconfig.org/
root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

# Markdown: trailing whitespace is semantic (two spaces = <br>).
[*.md]
trim_trailing_whitespace = false

# Data / config files: two-space convention.
[*.{yml,yaml,toml,json}]
indent_size = 2

# Web assets: two-space convention.
[*.{css,scss,html}]
indent_size = 2

# Rust
[*.rs]
indent_size = 4

# Justfile uses spaces.
[{Justfile,justfile}]
indent_style = space
indent_size  = 4

# Makefile must use tabs for recipe lines.
[Makefile]
indent_style = tab
