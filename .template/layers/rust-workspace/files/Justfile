set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set dotenv-load := false

# Compose service used for every cargo invocation. Generated by the
# `docker-dev` layer; the `rust-workspace` Justfile assumes Docker-only
# execution per the project's ADR-0002 equivalent.
DEV  := "docker compose run --rm dev"
CI   := "docker compose run --rm ci"

# Region-coverage gate. Day-1 floor; ratchet up as test surface grows.
COVERAGE_FLOOR := "92"

default:
    @just --list --unsorted

# ---------------------------------------------------------------------------
# Bootstrap
# ---------------------------------------------------------------------------

bootstrap:
    docker compose build dev
    just hooks

hooks:
    {{DEV}} lefthook install

hooks-uninstall:
    {{DEV}} lefthook uninstall

# Open an interactive shell in the dev container.
sh:
    {{DEV}} bash

# ---------------------------------------------------------------------------
# Build / run
# ---------------------------------------------------------------------------

build:
    {{DEV}} cargo build --workspace --all-targets

watch JOB="check":
    {{DEV}} bacon {{JOB}}

run +ARGS:
    {{DEV}} cargo run -- {{ARGS}}

# ---------------------------------------------------------------------------
# Lint / format
# ---------------------------------------------------------------------------

fmt:
    {{DEV}} cargo fmt --all

fmt-check:
    {{DEV}} cargo fmt --all -- --check

clippy:
    {{DEV}} cargo clippy --workspace --all-targets -- -D warnings

typos:
    {{DEV}} typos

# Reject patterns that mask real bugs even when type / lint gates pass.
strict-code:
    @echo "::group::strict-code"
    ! grep -rEn '\b(TODO|FIXME)\b' --include='*.rs' --exclude-dir=target . \
        | grep -vE '\(#[0-9]+\)' \
        || (echo "bare TODO/FIXME — add (#NN) issue link" && exit 1)
    ! grep -rEn '#\[allow\([a-z_:]+\)\]' --include='*.rs' --exclude-dir=target . \
        || (echo "#[allow(...)] missing reason = \"...\"" && exit 1)
    ! grep -rEn '\bunsafe[[:space:]]*\{' --include='*.rs' --exclude-dir=target . \
        || (echo "unsafe block detected" && exit 1)
    ! grep -rEn '#!\[feature\(' --include='*.rs' --exclude-dir=target . \
        || (echo "#![feature(...)] requires nightly — not allowed" && exit 1)
    @echo "::endgroup::"

actionlint:
    {{DEV}} actionlint || true

yamllint:
    {{DEV}} yamllint .

markdownlint:
    {{DEV}} markdownlint-cli2 "**/*.md" "#target"

lint: fmt-check clippy typos strict-code

# ---------------------------------------------------------------------------
# Test, coverage, audit
# ---------------------------------------------------------------------------

test:
    {{DEV}} cargo nextest run --workspace

coverage:
    {{DEV}} cargo llvm-cov --workspace \
        --fail-under-regions {{COVERAGE_FLOOR}} \
        --summary-only

audit:
    {{DEV}} cargo deny check
    {{DEV}} cargo audit

# ---------------------------------------------------------------------------
# Aggregate
# ---------------------------------------------------------------------------

ci: lint test coverage audit
