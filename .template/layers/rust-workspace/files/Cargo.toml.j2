[workspace]
resolver = "3"
members = ["crates/*"]
exclude = []

[workspace.package]
version       = "0.1.0"
edition       = "2024"
rust-version  = "1.95.0"
license       = "Apache-2.0 OR MIT"
description   = "{{ project.description }}"
repository    = "https://github.com/{{ project.owner }}/{{ project.name }}"
authors       = ["{{ project.author }}"]
readme        = "README.md"

# ---------------------------------------------------------------------------
# Workspace lints — single source of truth. Per-crate `[lints.*]` carve
# -outs are not allowed; per-crate exceptions go through the strict-code
# grep gate (see `just strict-code`).
# ---------------------------------------------------------------------------
[workspace.lints.rust]
unsafe_code      = "forbid"
non_ascii_idents = "deny"

missing_debug_implementations = "warn"
missing_copy_implementations  = "warn"
trivial_casts                 = "warn"
trivial_numeric_casts         = "warn"
unused_import_braces          = "warn"
unused_lifetimes              = "warn"
unused_qualifications         = "warn"

unreachable_pub                = "warn"
single_use_lifetimes           = "warn"
elided_lifetimes_in_paths      = "warn"
redundant_lifetimes            = "warn"
explicit_outlives_requirements = "warn"

let_underscore_drop         = "warn"
keyword_idents_2024         = "warn"
variant_size_differences    = "warn"
ambiguous_negative_literals = "warn"

dead_code = "deny"

rust_2024_compatibility = { level = "warn", priority = -1 }

[workspace.lints.rustdoc]
broken_intra_doc_links       = "deny"
private_intra_doc_links      = "warn"
invalid_codeblock_attributes = "warn"
invalid_html_tags            = "warn"
invalid_rust_codeblocks      = "warn"
bare_urls                    = "warn"
redundant_explicit_links     = "warn"
unescaped_backticks          = "warn"

[workspace.lints.clippy]
pedantic = { level = "warn", priority = -1 }
nursery  = { level = "warn", priority = -1 }
cargo    = { level = "warn", priority = -1 }

dbg_macro                  = "warn"
todo                       = "warn"
unimplemented              = "warn"
clone_on_ref_ptr           = "warn"
unnecessary_safety_comment = "warn"
unnecessary_safety_doc     = "warn"
missing_assert_message     = "warn"

# Hand-picked restriction lints. The full restriction group is NOT enabled —
# it contains mutually contradictory lints; each entry here is deliberate.
str_to_string                   = "warn"
absolute_paths                  = "warn"
allow_attributes_without_reason = "warn"
empty_structs_with_brackets     = "warn"
if_then_some_else_none          = "warn"
let_underscore_must_use         = "warn"
mixed_read_write_in_expression  = "warn"
rest_pat_in_fully_bound_structs = "warn"
same_name_method                = "warn"
semicolon_outside_block         = "warn"
try_err                         = "warn"
unneeded_field_pattern          = "warn"
verbose_file_reads              = "warn"
format_push_string              = "warn"
unnecessary_self_imports        = "warn"
assertions_on_result_states     = "warn"
filetype_is_file                = "warn"
rc_buffer                       = "warn"
rc_mutex                        = "warn"
lossy_float_literal             = "warn"
suspicious_xor_used_as_pow      = "warn"

# Justified carve-outs.
module_name_repetitions = "allow" # crate-name-prefix on module-level items reads cleaner than fighting this
multiple_crate_versions = "allow" # transitive collisions are upstream's problem
missing_const_for_fn    = "allow" # pre-1.0 churn — revisit at API stabilisation
redundant_pub_crate     = "allow" # conflicts with rustc's `unreachable_pub`

[workspace.dependencies]
# Add per-project shared dependencies here. Keep this table the single
# source of truth for version pins so each member crate just declares
# `name = { workspace = true }`.

[profile.release]
lto           = "thin"
codegen-units = 1
strip         = "symbols"
panic         = "abort"
opt-level     = 3

[profile.bench]
inherits = "release"
strip    = "none"
debug    = 1

[profile.dev]
split-debuginfo = "unpacked"

[profile.dev.package."*"]
opt-level = 1
