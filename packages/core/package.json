{
  "name": "@booking/core",
  "version": "0.0.0",
  "description": "Industry-agnostic time-slot booking core: pure domain + application ports.",
  "license": "(Apache-2.0 OR MIT)",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    },
    "./application": {
      "types": "./dist/application/index.d.ts",
      "import": "./dist/application/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run --reporter=verbose test/property"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "effect": "^3.21.0",
    "typeid-js": "^1.2.0",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "expect-type": "^1.3.0",
    "fast-check": "^4.7.0",
    "vitest": "^4.1.0"
  }
}
