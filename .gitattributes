* text=auto eol=lf

# License / notice text files must stay LF on every checkout.
LICENSE-* text eol=lf
NOTICE    text eol=lf

# Generated artifacts from snapshot tests — large diffs, rare manual edits.
.template/tmpl/tests/snapshots/*.snap linguist-generated=true

# Lockfile is generated, don't expand by default in diffs.
Cargo.lock linguist-generated=true
